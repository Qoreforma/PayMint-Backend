{
  "name": "opabills",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev  -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "create:superAdmin": "ts-node src/seeders/createSuperAdmin.ts",
    "create:systemUser": "ts-node src/seeders/createSystemUser.ts",
    "create:plans": "ts-node src/seeders/createPlans.ts",
    "create:role": "ts-node src/seeders/createSuperAdminRole.ts",
    "seed:giftcard": "ts-node src/seeders/seedGiftcardProducts.ts",
    "seed:cashbacks": "ts-node src/seeders/seedCashbacks.ts",
    "seed:location": "ts-node src/scripts/seedReferenceData.ts",
    "update:banks": "ts-node src/scripts/updatebanks.ts",
    "cleanup:duplicateBanks": "ts-node src/scripts/cleanupDuplicateBanks.ts",
    "cleanup:leaderboard-periods": "ts-node -r tsconfig-paths/register src/script/cleanupInactiveLeaderboardPeriods.ts",
    "update:countries": "ts-node src/scripts/updateCountryWithFlag.ts",
    "sync:products": "ts-node src/scripts/seedProductsProvider.ts",
    "sync:p-s-stp": "ts-node src/scripts/seedProvidersServicesServiceType.ts",
    "migrate:providers": "ts-node src/scripts/migrateProviders.ts",
    "backfill:safehaven-autosweep": "ts-node -r tsconfig-paths/register src/script/backfillSafeHavenAutoSweep.ts",
    "recover:safehaven-trapped-funds": "ts-node -r tsconfig-paths/register src/script/recoverTrappedSafeHavenFunds.ts",
    "backfill:webhook-subscriptions": "ts-node -r tsconfig-paths/register src/script/backfillWebhookSubscriptions.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:critical": "jest tests/critical --verbose --detectOpenHandles",
    "test:webhooks": "jest tests/webhook --verbose --detectOpenHandles --runInBand -- --bail=false",
    "test:giftcard": "jest tests/giftcard --verbose --detectOpenHandles",
    "test:crypto": "jest tests/crypto --verbose --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='unit'",
    "test:integration": "jest --testPathPattern='integration'",
    "test:load": "jest --testPathPattern='load' --maxWorkers=1 --forceExit --timeout=60000"
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@sentry/tracing": "^7.120.4",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limiter": "^1.3.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "imagekit": "^6.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.1.1",
    "mongoose": "^8.21.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.9",
    "nodemon": "^3.1.10",
    "otplib": "^13.3.0",
    "rate-limit-redis": "^4.2.3",
    "redis": "^5.8.3",
    "resend": "^6.4.1",
    "sanitize-html": "^2.17.5",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@jest/reporters": "^30.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.19.41",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "jest-serial-runner": "^1.2.2",
    "mongodb-memory-server": "^11.0.1",
    "nock": "^14.0.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
